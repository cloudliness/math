{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "nixpacks",
        "packages": [
            "nodejs"
        ],
        "buildCommand": "cd frontend && npm install && npm run build && cd ../backend && mkdir -p static && cp -r ../frontend/dist/* static/"
    },
    "deploy": {
        "startCommand": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port $PORT",
        "healthcheckPath": "/health",
        "restartPolicy": {
            "type": "ON_FAILURE"
        }
    }
}