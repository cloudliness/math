{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "nixpacks",
        "buildCommand": "cd frontend && npm install && npm run build && cd ../backend && cp -r ../frontend/dist static"
    },
    "deploy": {
        "startCommand": "cd backend && uvicorn app.main:app --host 0.0.0.0 --port $PORT",
        "healthcheckPath": "/health",
        "restartPolicy": {
            "type": "ON_FAILURE"
        }
    }
}